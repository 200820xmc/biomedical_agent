# ===========================================
# AVF Research Assistant 配置文件
# 复制此文件为 .env 并填入真实值
# ===========================================

APP_NAME=AVF-Research-Assistant
DEBUG=True
HOST=0.0.0.0
PORT=9900

# 阿里云 DashScope API（通义千问）
# 申请地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Milvus 向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# RAG 检索配置
RAG_TOP_K=5
RAG_MODEL=qwen-max

# 文档分块配置
CHUNK_MAX_SIZE=2400
CHUNK_OVERLAP=200

# MCP 服务（预留，可接入 PubMed 等外部工具）
# transport: stdio | sse | streamable-http
# MCP_PUBMED_URL=http://localhost:8003/mcp
