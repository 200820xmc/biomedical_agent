# AVF Research Assistant 配置模板
# 复制为 .env 后填写真实值；不要提交包含真实密钥的 .env。

APP_NAME=AVF-Research-Assistant
APP_VERSION=2.0.0
DEBUG=False
HOST=0.0.0.0
PORT=9900

# DashScope / 通义千问
DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# Agent生成模型
RAG_MODEL=qwen-max
RAG_TOP_K=5

# 两阶段检索
RAG_CANDIDATE_K=50
RAG_RERANK_K=20
RAG_FINAL_CHUNKS=8
RAG_MAX_SOURCES=5
RAG_MAX_CHUNKS_PER_SOURCE=2

# LLM Rerank
RAG_RERANK_ENABLED=True
RAG_RERANK_MODEL=
RAG_RERANK_THRESHOLD=0.65

# 上下文预算
RAG_MAX_CONTEXT_TOKENS=6000
RAG_MAX_CONTEXT_CHARS=12000
RAG_MAX_CHARS_PER_EVIDENCE=1600

# Query处理：当前默认关闭
RAG_QUERY_REWRITE_ENABLED=False
RAG_MULTI_QUERY_ENABLED=False
RAG_MULTI_QUERY_COUNT=3

# 文档分块
# 注意：当前递归分割器实际使用 CHUNK_MAX_SIZE * 2，
# 因此1600配置对应约3200字符的二次分割目标上限。
CHUNK_MAX_SIZE=1600
CHUNK_OVERLAP=200
MIN_CHUNK_SIZE=300

# xParse PDF解析
XPARSE_CLI_PATH=C:\Users\your-user\.xparse-cli\bin\xparse-cli.exe
XPARSE_API_MODE=free
XPARSE_APP_ID=
XPARSE_SECRET_CODE=
XPARSE_BASE_URL=
XPARSE_TIMEOUT_SECONDS=600
XPARSE_MAX_RETRIES=1
XPARSE_MAX_CONCURRENCY=1
XPARSE_INCLUDE_IMAGE_DATA=False
PDF_MAX_FILE_SIZE=10485760

# MCP（可选；当前未配置外部服务）
# MCP_PUBMED_URL=http://localhost:8003/mcp
